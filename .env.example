# VivuRouter Go
HOSTNAME=127.0.0.1
PORT=20129
DATA_DIR=./data
DEBUG=false

# Persistence backend: file (JSON, default) hoặc sqlite (pure-Go, không cần cgo)
STORE_BACKEND=file

# Thời gian tối đa (giây) để drain request khi nhận SIGINT/SIGTERM
SHUTDOWN_TIMEOUT=15

# Optional local API key enforcement for /v1/*
REQUIRE_API_KEY=false
LOCAL_API_KEY=sk-local-demo

# Seed provider values used only when data/sample-db.json does not exist
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODELS=gpt-4.1,gpt-4o-mini

CODEX_BASE_URL=https://chatgpt.com/backend-api/codex/responses
CODEX_ACCESS_TOKEN=
CODEX_MODELS=gpt-5-codex

# Optional global pricing override, USD per 1M tokens. Nếu bỏ trống, sample dùng pricing mặc định nhỏ cho vài model OpenAI và 0 cho Codex.
USAGE_PRICE_INPUT_PER_1M=
USAGE_PRICE_OUTPUT_PER_1M=
USAGE_PRICE_CACHED_INPUT_PER_1M=
USAGE_PRICE_REASONING_PER_1M=
